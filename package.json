{
  "name": "params-l5",
  "version": "0.0.2",
  "description": "package to generate  l5repository query strings",
  "keywords": [
    "l5",
    "params",
    "repository"
  ],
  "homepage": "https://github.com/LuisCunha05/paramsL5#readme",
  "bugs": {
    "url": "https://github.com/LuisCunha05/paramsL5/issues"
  },
  "license": "MIT",
  "author": "luiscunha05",
  "repository": {
    "type": "git",
    "url": "https://github.com/LuisCunha05/paramsL5.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsc && tsdown",
    "test": "vitest --config vitest.config.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "tsdown": "^0.17.0",
    "typescript": "^7.0.2",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
