{
  "name": "params-l5",
  "version": "0.0.2",
  "description": "package to generate  l5repository query strings",
  "keywords": [
    "l5",
    "params",
    "repository"
  ],
  "homepage": "https://github.com/LuisCunha05/paramsL5#readme",
  "bugs": {
    "url": "https://github.com/LuisCunha05/paramsL5/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LuisCunha05/paramsL5.git"
  },
  "license": "MIT",
  "author": "luiscunha05",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "test": "vitest --config vitest.config.ts",
    "lint": "tsc",
    "build": "tsc && tsdown",
    "format": "biome check --write src/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "tsdown": "^0.17.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
